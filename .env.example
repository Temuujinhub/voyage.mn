# Voyage E-Boarding — production environment
# cp .env.example .env  and fill in real values. NEVER commit .env.

# strong random password for the postgres user (e.g. `openssl rand -hex 24`)
DB_PASSWORD=

# secrets for JWT auth and boarding pass QR signing (e.g. `openssl rand -hex 32`)
JWT_SECRET=
QR_SECRET=

# initial admin password used on first seed (change after first login)
ADMIN_PASSWORD=

# public URL of the system
PUBLIC_BASE_URL=https://voyage.mn
